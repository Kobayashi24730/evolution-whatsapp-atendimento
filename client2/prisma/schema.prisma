generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Atendimento {
  id              String             @id @default(uuid())
  clienteNumero   String
  clienteNome     String?
  clienteAvatar   String?
  clienteCpf      String?
  clienteEmail    String?

  contratoId      String?
  contratoPlano   String?
  contratoStatus  String?

  status          String             @default("ABERTO")
  aba             String             @default("GERAL")
  unreadCount     Int                @default(0)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  userId          String?
  user            User?              @relation(fields: [userId], references: [id])

  mensagens       Mensagem[]
  etiquetas       AtendimentoTag[]
  @@map("Atendimento")
}

model Mensagem {
  id            String      @id @default(uuid())
  texto         String?
  tipo          String      @default("TEXTO")
  mediaUrl      String?
  mediaName     String?
  caption       String?

  fromMe        Boolean     @default(false)
  lida          Boolean     @default(false)
  timestamp     DateTime    @default(now())

  atendimentoId String
  atendimento   Atendimento @relation(fields: [atendimentoId], references: [id], onDelete: Cascade)
  @@map("Mensagem")
}

model Etiqueta {
  id          String           @id @default(uuid())
  nome        String
  cor         String           @default("#3B82F6")
  atendimentos AtendimentoTag[]
  @@map("Etiqueta")
}

model AtendimentoTag {
  atendimentoId String
  etiquetaId    String

  atendimento   Atendimento @relation(fields: [atendimentoId], references: [id], onDelete: Cascade)
  etiqueta      Etiqueta    @relation(fields: [etiquetaId], references: [id], onDelete: Cascade)

  @@id([atendimentoId, etiquetaId])
  @@map("AtendimentoTag")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           Int      @id @default(autoincrement())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String        @id @default(uuid())
  name          String
  email         String        @unique
  createdAt     DateTime      @default(now())
  emailVerified Boolean       @default(false)
  image         String?
  password      String?
  accounts      Account[]
  atendimentos  Atendimento[]
  sessions      Session[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

enum StatusAtendimento {
  TRIAGEM
  AGUARDANDO_HUMANO
  EM_ATENDIMENTO
  FINALIZADO
}
